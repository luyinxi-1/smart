      "数据库中需要存在题库ID=1",
      "数据库中需要存在教学素材ID=1,2,3,4,5"
    ],
    "测试工具": [
      "Postman",
      "ApiPost",
      "Swagger",
      "JUnit"
    ],
    "注意事项": [
      "id字段在新增时设置为0或不传",
      "name字段为必填项，不能为空",
      "status: 0=未发布，1=已发布",
      "textbookCatalogId和textbookCatalogUuId二选一即可",
