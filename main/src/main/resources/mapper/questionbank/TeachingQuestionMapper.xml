<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.upc.modular.questionbank.mapper.TeachingQuestionMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.upc.modular.questionbank.entity.TeachingQuestion">
        <id column="id" property="id" />
        <result column="type" property="type" />
        <result column="content" property="content" />
        <result column="difficulty" property="difficulty" />
        <result column="status" property="status" />
        <result column="answer" property="answer" />
        <result column="subject" property="subject" />
        <result column="teaching_question_classification_id" property="teachingQuestionClassificationId" />
        <result column="choice_question_options" property="choiceQuestionOptions" />
        <result column="answer_analysis" property="answerAnalysis" />
        <result column="creator" property="creator" />
        <result column="add_datetime" property="addDatetime" />
        <result column="operator" property="operator" />
        <result column="operation_datetime" property="operationDatetime" />
        <result column="textbook_id" property="textbookId" />
        <result column="textbook_name" property="textbookName" />
        <result column="chapter_id" property="chapterId" />
        <result column="chapter_name" property="chapterName" />
        <result column="creatorName" property="creatorName"/> <!-- 非数据库字段 -->
    </resultMap>
    <resultMap id="PageSearchResultMap" type="com.upc.modular.questionbank.controller.param.TeachingQuestionPageSearchReturnVO">
        <id column="id" property="id" />
        <result column="type" property="type" />
        <result column="content" property="content" />
        <result column="difficulty" property="difficulty" />
        <result column="status" property="status" />
        <result column="answer" property="answer" />
        <result column="subject" property="subject" />
        <result column="teaching_question_classification_id" property="teachingQuestionClassificationId" />
        <result column="choice_question_options" property="choiceQuestionOptions" />
        <result column="answer_analysis" property="answerAnalysis" />
        <result column="creator" property="creator" />
        <result column="add_datetime" property="addDatetime" />
        <result column="operator" property="operator" />
        <result column="operation_datetime" property="operationDatetime" />
        <result column="textbook_id" property="textbookId" />
        <result column="textbook_name" property="textbookName" />
        <result column="chapter_id" property="chapterId" />
        <result column="chapter_name" property="chapterName" />
        <result column="teaching_question_classification_name" property="teachingQuestionClassificationName" />
        <result column="creatorName" property="creatorName"/>
    </resultMap>

    <select id="selectQuestion" resultMap="PageSearchResultMap">
        SELECT
        t.id, t.type, t.content, t.difficulty, t.status, t.answer, t.subject,
        t.creator, t.add_datetime, t.operator, t.operation_datetime,
        t.teaching_question_classification_id, t.textbook_id, t.textbook_name,
        t.chapter_id, t.chapter_name,
        -- 【新增】关联查询出题目分类的名称
        tqc.teaching_question_classification_name
        -- 【修改】FROM 语句，使用 LEFT JOIN 关联题目分类表
        FROM teaching_question t
        LEFT JOIN teaching_question_classification tqc ON t.teaching_question_classification_id = tqc.id
        <where>
            <!-- 题目内容模糊查询 -->
            <if test="param.content != null and param.content != ''">
                AND t.content LIKE CONCAT('%', #{param.content}, '%')
            </if>
            <!-- 【新增】题目分类名称模糊查询 -->
            <if test="param.teachingQuestionClassificationName != null and param.teachingQuestionClassificationName != ''">
                AND tqc.teaching_question_classification_name LIKE CONCAT('%', #{param.teachingQuestionClassificationName}, '%')
            </if>
            <!-- 题型精确查询 -->
            <if test="param.type != null">
                AND t.type = #{param.type}
            </if>
            <!-- 状态精确查询 -->
            <if test="param.status != null">
                AND t.status = #{param.status}
            </if>
            <!-- 所属学科模糊查询 -->
            <if test="param.subject != null and param.subject != ''">
                AND t.subject LIKE CONCAT('%', #{param.subject}, '%')
            </if>

            <!-- a. 增加的查询参数 -->
            <if test="param.difficulty != null">
                AND t.difficulty = #{param.difficulty}
            </if>
            <if test="param.textbookName != null and param.textbookName != ''">
                AND t.textbook_name LIKE CONCAT('%', #{param.textbookName}, '%')
            </if>
            <if test="param.textbookId != null">
                AND t.textbook_id = #{param.textbookId}
            </if>
            <if test="param.chapterId != null">
                AND t.chapter_id = #{param.chapterId}
            </if>

            <!-- 【已恢复】条件: 根据题目分类ID查询该分类及所有子分类的题目 -->
            <if test="param.classificationId != null">
                AND (t.teaching_question_classification_id = #{param.classificationId}
                OR t.teaching_question_classification_id IN (
                SELECT id FROM teaching_question_classification
                WHERE parent_id = #{param.classificationId}
                OR parent_id IN (
                SELECT id FROM teaching_question_classification
                WHERE parent_id = #{param.classificationId}
                )
                )
                )
            </if>
            <!-- b. 权限控制 -->
            <!-- 如果当前用户不是管理员, 则增加一个查询条件，只查询 creator 是自己的记录 -->
            <if test="!isAdmin">
                AND t.creator = #{userId}
            </if>
        </where>
        ORDER BY t.add_datetime
        <choose>
            <when test="param.isAsc == 1">ASC</when>
            <otherwise>DESC</otherwise>
        </choose>
    </select>

    <select id="selectQuestionById" resultMap="BaseResultMap">
        SELECT
            t.id,                                -- 题目的主键 ID
            t.type,                              -- 题目类型
            t.content,                           -- 题目内容
            t.difficulty,                        -- 难度等级
            t.status,                            -- 状态（启用/禁用）
            t.answer,                            -- 正确答案
            t.subject,                           -- 所属学科
            t.creator,                           -- 创建人（外键，关联 sys_tbuser 表）
            t.add_datetime,                      -- 创建时间
            t.operator,                          -- 最后操作人
            t.operation_datetime,                -- 最后操作时间
            t.teaching_question_classification_id, -- 题目分类 ID
            t.choice_question_options,           -- 选择题的选项（如果是选择题）
            t.answer_analysis,                   -- 答案解析
            u.nickname AS creatorName            -- 通过用户表 sys_tbuser 查出来的创建人姓名，别名为 creatorName
        FROM teaching_question t                 -- 主表：题目表
                 LEFT JOIN sys_tbuser u          -- 左连接用户表
                           ON t.creator = u.id             -- 条件：题目表的 creator 对应用户表的 id
        WHERE t.id = #{id}                       -- 只查询指定题目的数据
    </select>
</mapper>