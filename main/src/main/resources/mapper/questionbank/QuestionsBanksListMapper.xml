<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.upc.modular.questionbank.mapper.QuestionsBanksListMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.upc.modular.questionbank.entity.QuestionsBanksList">
        <id column="id" property="id" />
        <result column="question_id" property="questionId" />
        <result column="bank_id" property="bankId" />
        <result column="order" property="order" />
        <result column="score" property="score" />
    </resultMap>

    <select id="selectQuestionPageList" resultMap="BaseResultMap">
        SELECT
        t.id,
        t.question_id,
        t.bank_id,
        t.order,
        t.score
        FROM
        questions_banks_list t
        <where>
            <!-- 条件1: 根据题目ID精确查询 -->
            <if test="param.questionId != null">
                AND t.question_id = #{param.questionId}
            </if>
            <!-- 条件2: 根据题库ID精确查询 -->
            <if test="param.bankId != null">
                AND t.bank_id = #{param.bankId}
            </if>
            <!-- 条件3: 根据顺序精确查询 -->
            <if test="param.order != null">
                AND t.order = #{param.order}
            </if>
            <!-- 条件4: 根据分值精确查询 -->
            <if test="param.score != null">
                AND t.score = #{param.score}
            </if>
        </where>
        ORDER BY t.order
        <choose>
            <when test="param.isAsc != null and param.isAsc == 1">ASC</when>
            <otherwise>DESC</otherwise>
        </choose>
    </select>
</mapper>
