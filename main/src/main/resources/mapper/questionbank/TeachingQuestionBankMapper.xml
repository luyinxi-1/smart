<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.upc.modular.questionbank.mapper.TeachingQuestionBankMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.upc.modular.questionbank.entity.TeachingQuestionBank">
        <id column="id" property="id" />
        <result column="name" property="name" />
        <result column="description" property="description" />
        <result column="status" property="status" />
        <result column="textbook_id" property="textbookId" />
        <result column="textbook_catalog_id" property="textbookCatalogId" />
        <result column="textbook_catalog_id2" property="textbookCatalogId2" />
        <result column="max_attempts" property="maxAttempts" />
        <result column="score_policy" property="scorePolicy" />
        <result column="creator" property="creator" />
        <result column="add_datetime" property="addDatetime" />
        <result column="operator" property="operator" />
        <result column="operation_datetime" property="operationDatetime" />
    </resultMap>

    <!-- 分页查询题库列表 -->
    <select id="selectQuestionBank"
            resultType="com.upc.modular.questionbank.controller.param.TeachingQuestionBankPageMidReturnParam">
        SELECT
        t.id, -- 主键
        t.name,
        t.description,
        t.status,
        t.textbook_id AS textbookId,
        tb.textbook_name as textbookName,
        t.textbook_catalog_id AS textbookCatalogId,
        t.textbook_catalog_id2 AS textbookCatalogId2,
        t.max_attempts AS maxAttempts,
        t.score_policy AS scorePolicy,
        t.creator,
        u.nickname AS creatorName,
        t.add_datetime AS addDatetime,
        COUNT(qbl.id) AS questionCount,
        tb.release_status AS releaseStatus
        FROM
        teaching_question_bank t
        LEFT JOIN questions_banks_list qbl ON t.id = qbl.bank_id
        LEFT JOIN sys_tbuser u ON t.creator = u.id
        LEFT JOIN textbook tb ON t.textbook_id = tb.id
        <where>
            <!-- 教师只能看自己创建的 -->
            <if test="userRole != null and userRole == 'teacher'">
                AND t.creator = #{userId}
            </if>

            <!-- 条件1: 根据题库名称模糊查询 -->
            <if test="param.name != null and param.name != ''">
                AND t.name LIKE CONCAT('%', #{param.name}, '%')
            </if>

            <!-- 条件2: 根据题库说明模糊查询 -->
            <if test="param.description != null and param.description != ''">
                AND t.description LIKE CONCAT('%', #{param.description}, '%')
            </if>

            <!-- 条件3: 根据教学题库状态精确查询 -->
            <if test="param.status != null">
                AND t.status = #{param.status}
            </if>

            <!-- ===============================
                 核心：未绑定模式 / 普通模式 分支
                 =============================== -->

            <!-- 未绑定模式：isUnbound = 1 -->
            <if test="param.isUnbound != null and param.isUnbound == 1">

                <!-- 规则 3：凡是 textbook_catalog_id 有值，说明题库已经绑定章节，统统排除 -->
                AND t.textbook_catalog_id IS NULL

                <choose>
                    <!-- 有 textbookId 的情况：按当前教材维度筛选 -->
                    <when test="param.textbookId != null">
                        AND t.textbook_id = #{param.textbookId}

                        <choose>
                            <!-- 场景 2：textbookCatalogId2 有真实值（>0），当前章节已入库 -->
                            <when test="param.textbookCatalogId2 != null and param.textbookCatalogId2 != 0">
                                <!--
                                    规则 2：
                                    - 属于当前教材；
                                    - textbook_catalog_id 仍为空（未正式绑定章节）；
                                    - textbook_catalog_id2 在目标目录ID列表中 或 textbook_catalog_id2 为空
                                  -->
                                AND (
                                <if test="param.targetCatalogIds != null and !param.targetCatalogIds.isEmpty()">
                                    t.textbook_catalog_id2 IN
                                    <foreach collection="param.targetCatalogIds" item="catalogId" open="(" separator="," close=")">
                                        #{catalogId}
                                    </foreach>
                                </if>
                                <if test="param.targetCatalogIds == null or param.targetCatalogIds.isEmpty()">
                                    t.textbook_catalog_id2 = #{param.textbookCatalogId2}
                                </if>
                                OR t.textbook_catalog_id2 IS NULL
                                )
                            </when>

                            <!-- 场景 1：textbookCatalogId2 未传或 =0，临时章节 -->
                            <otherwise>
                                <!--
                                    规则 1：
                                    - 属于当前教材；
                                    - textbook_catalog_id 为空（未绑定章节）；
                                    - textbook_catalog_id2 也为空（没有临时占用记录）
                                  -->
                                AND t.textbook_catalog_id2 IS NULL
                            </otherwise>
                        </choose>
                    </when>

                    <!-- 没有 textbookId 的情况：全局"未绑定章节"模式 -->
                    <otherwise>
                        <!--
                            这里仅依赖上面的
                            AND t.textbook_catalog_id IS NULL
                            即：只要没绑定任何章节的题库，都算未绑定题库
                            （textbook_id 可以为 null 或某本教材，看你后续是否要再限制）
                        -->
                    </otherwise>
                </choose>
            </if>

            <!-- 普通模式：isUnbound != 1 -->
            <if test="param.isUnbound == null || param.isUnbound != 1">
                <!-- 条件4: 根据关联教材ID精确查询 -->
                <if test="param.textbookId != null">
                    AND t.textbook_id = #{param.textbookId}
                </if>

                <!-- 条件5: 优先根据备用教材目录 ID（编辑章节使用） -->
                <if test="param.textbookCatalogId2 != null and param.textbookCatalogId2 != 0">
                    AND t.textbook_catalog_id2 = #{param.textbookCatalogId2}
                </if>

                <!-- 条件6: 再根据正式教材目录 ID 精确查询 -->
                <if test="param.textbookCatalogId != null">
                    AND t.textbook_catalog_id = #{param.textbookCatalogId}
                </if>
            </if>

            <!-- 条件7: 根据答题次数限制精确查询 -->
            <if test="param.maxAttempts != null">
                AND t.max_attempts = #{param.maxAttempts}
            </if>

            <!-- 条件8: 根据成绩取值方式精确查询 -->
            <if test="param.scorePolicy != null">
                AND t.score_policy = #{param.scorePolicy}
            </if>
        </where>

        GROUP BY
        t.id, t.name, t.description, t.status, t.textbook_id, tb.textbook_name,
        t.textbook_catalog_id, t.textbook_catalog_id2,
        t.max_attempts, t.score_policy,
        t.creator, u.nickname, t.add_datetime, tb.release_status
        ORDER BY
        t.add_datetime
        <choose>
            <when test="param.isAsc != null and param.isAsc == 1">ASC</when>
            <otherwise>DESC</otherwise>
        </choose>
    </select>


