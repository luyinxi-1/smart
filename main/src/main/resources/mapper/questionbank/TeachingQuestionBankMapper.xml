<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.upc.modular.questionbank.mapper.TeachingQuestionBankMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.upc.modular.questionbank.entity.TeachingQuestionBank">
        <id column="id" property="id" />
        <result column="name" property="name" />
        <result column="description" property="description" />
        <result column="status" property="status" />
        <result column="textbook_id" property="textbookId" />
        <result column="textbook_catalog_id" property="textbookCatalogId" />
        <result column="max_attempts" property="maxAttempts" />
        <result column="score_policy" property="scorePolicy" />
        <result column="creator" property="creator" />
        <result column="add_datetime" property="addDatetime" />
        <result column="operator" property="operator" />
        <result column="operation_datetime" property="operationDatetime" />
    </resultMap>


    <select id="selectQuestionBank" resultType="com.upc.modular.questionbank.controller.param.TeachingQuestionBankPageMidReturnParam">
        SELECT
        t.id, -- 注意：我们需要id来做GROUP BY
        t.name,
        t.description,
        t.status,
        t.textbook_id AS textbookId, -- 使用别名直接映射到驼峰属性
        t.textbook_catalog_id AS textbookCatalogId,
        t.max_attempts AS maxAttempts,
        t.score_policy AS scorePolicy,
        t.creator,
        t.add_datetime AS addDatetime,
        COUNT(qbl.id) AS questionCount
        FROM
        teaching_question_bank t
        LEFT JOIN
        questions_banks_list qbl ON t.id = qbl.bank_id
        <where>
            <!-- 条件1: 根据题库名称模糊查询 -->
            <if test="param.name != null and param.name != ''">
                AND t.name LIKE CONCAT('%', #{param.name}, '%')
            </if>
            <!-- 条件2: 根据题库说明模糊查询 -->
            <if test="param.description != null and param.description != ''">
                AND t.description LIKE CONCAT('%', #{param.description}, '%')
            </if>
            <!-- 条件3: 根据教学题库状态精确查询 -->
            <if test="param.status != null">
                AND t.status = #{param.status}
            </if>
            <!-- 条件4: 根据关联教材ID精确查询 -->
            <if test="param.textbookId != null">
                AND t.textbook_id = #{param.textbookId}
            </if>
            <!-- 条件5: 根据关联教材目录ID精确查询 (这是导致你报错的关键点) -->
            <if test="param.textbookCatalogId != null">
                AND t.textbook_catalog_id = #{param.textbookCatalogId}
            </if>
            <!-- 条件6: 根据答题次数限制精确查询 -->
            <if test="param.maxAttempts != null">
                AND t.max_attempts = #{param.maxAttempts}
            </if>
            <!-- 条件7: 根据成绩取值方式精确查询 -->
            <if test="param.scorePolicy != null">
                AND t.score_policy = #{param.scorePolicy}
            </if>
        </where>
        GROUP BY
        t.id
        ORDER BY
        t.add_datetime
        <choose>
            <when test="param.isAsc != null and param.isAsc == 1">ASC</when>
            <otherwise>DESC</otherwise>
        </choose>
    </select>
</mapper>
