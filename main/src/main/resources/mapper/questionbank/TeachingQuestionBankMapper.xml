    <select id="selectQuestionBanksWithPendingStatus" resultType="com.upc.modular.questionbank.controller.param.QuestionBankWithStatusVO">
        SELECT
        tqb.id AS bankId,
        tqb.name AS bankName,
        tqb.textbook_catalog_id AS catalogId,
        tc.catalog_name AS catalogName,
        COUNT(DISTINCT ser.id) AS pendingReviewCount
        FROM
        teaching_question_bank tqb
        LEFT JOIN
        textbook_catalog tc ON tqb.textbook_catalog_id = tc.id
        LEFT JOIN
        student_exercises_record ser ON tqb.id = ser.teaching_question_bank_id AND ser.status = 1
        WHERE
        tqb.textbook_id = #{textbookId,jdbcType=BIGINT}
        <if test="textbookCatalogId != null">
            AND tqb.textbook_catalog_id = #{textbookCatalogId,jdbcType=BIGINT}
        </if>
        <if test="teachingQuestionBankName != null and teachingQuestionBankName != ''">
            AND tqb.name LIKE CONCAT('%', #{teachingQuestionBankName,jdbcType=VARCHAR}, '%')
        </if>
        GROUP BY
        tqb.id, tqb.name, tqb.textbook_catalog_id, tc.catalog_name
        ORDER BY
        CASE WHEN COUNT(DISTINCT ser.id) > 0 THEN 0 ELSE 1 END ASC,
        tqb.textbook_catalog_id ASC,
        tqb.id ASC
    </select>

    <select id="selectGradingSituationPage" resultType="com.upc.modular.questionbank.controller.param.GradingSituationReturnVO">
        SELECT
            sfg.student_id AS studentId,
            g.name AS className,
            s.identity_id AS identityId,
            s.name AS studentName,
            sfg.final_score AS finalScore,
            sfg.bank_id AS bankId,
            sfg.record_id AS recordId,
            sfg.update_time AS addDatetime
        FROM
            student_final_grade sfg
                JOIN
            student s ON sfg.student_id = s.id
                LEFT JOIN
            "group" g ON s.class_id = g.id
        WHERE
            sfg.bank_id = #{param.bankId}
        ORDER BY
            sfg.final_score DESC, s.id ASC
    </select>

    <select id="selectStudentAnswerDetailsByRecordId" resultType="com.upc.modular.questionbank.controller.param.StudentAnswerDetailVO">
        SELECT
            sec.teaching_question AS teachingQuestionId,
            tq.type AS questionType,
            tq.content AS questionContent,
            sec.content AS studentAnswer,
            tq.answer AS correctAnswer,
            sec.score AS studentScore,
            qbl.score AS maxScore,
            tq.choice_question_options AS choiceQuestionOptions
        FROM
            student_exercises_content sec
                JOIN
            teaching_question tq ON sec.teaching_question = tq.id
                LEFT JOIN
            questions_banks_list qbl ON sec.teaching_question = qbl.question_id AND sec.teaching_question_bank_id = qbl.bank_id
        WHERE
            sec.record_id = #{recordId}
        ORDER BY
            qbl.sequence ASC, qbl.id ASC
    </select>

    <select id="selectPendingReviewRawDataForBank" resultType="com.upc.modular.questionbank.controller.param.PendingReviewRawDataVO">
        SELECT
            tq.id AS questionId,
            tq.content AS questionContent,
            tq.answer AS correctAnswer,
            tq.answer_analysis AS answerAnalysis,
            qbl.score AS maxScore,
            sec.id AS contentId,
            sec.record_id AS recordId,
            s.name AS studentName,
            sec.content AS studentAnswer
        FROM
            student_exercises_content sec
                JOIN
            student_exercises_record ser ON sec.record_id = ser.id
                JOIN
            teaching_question tq ON sec.teaching_question = tq.id
                JOIN
            teaching_question_bank tqb ON ser.teaching_question_bank_id = tqb.id
                JOIN
            textbook tb ON tqb.textbook_id = tb.id
                LEFT JOIN
            questions_banks_list qbl ON tq.id = qbl.question_id AND tqb.id = qbl.bank_id
                LEFT JOIN
            student s ON ser.student_id = s.id
        WHERE
            ser.teaching_question_bank_id = #{param.bankId}
          AND ser.status = 1
          AND tq.type = 5
          AND sec.score IS NULL
        ORDER BY
            -- 必须先按题目ID排序，便于后续分组
            tq.id ASC,
            s.id ASC
    </select>
</mapper>