<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.upc.modular.questionbank.mapper.StudentExercisesContentMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.upc.modular.questionbank.entity.StudentExercisesContent">
        <id column="id" property="id" />
        <result column="student_id" property="studentId" />
        <result column="record_id" property="recordId" />
        <result column="teaching_question" property="teachingQuestion" />
        <result column="content" property="content" />
        <result column="result" property="result" />
        <result column="score" property="score" />
        <result column="teaching_question_bank_id" property="teachingQuestionBankId" />
        <result column="creator" property="creator" />
        <result column="add_datetime" property="addDatetime" />
        <result column="operator" property="operator" />
        <result column="operation_datetime" property="operationDatetime" />
    </resultMap>

    <!-- 分页查询学生做题内容记录 -->
    <select id="selectStudentExercisesContentPage" resultMap="BaseResultMap">
        SELECT
        sec.id,
        sec.student_id,
        sec.teaching_question,
        sec.record_id,
        sec.content,
        sec.result,
        sec.score,
        sec.teaching_question_bank_id,
        sec.creator,
        sec.add_datetime,
        sec.operator,
        sec.operation_datetime
        FROM student_exercises_content sec
        <where>
            <if test="param.id != null">
                AND sec.id = #{param.id}
            </if>
            <!-- 条件1: 根据学生ID精确查询 -->
            <if test="param.studentId != null">
                AND sec.student_id = #{param.studentId}
            </if>
            <!-- 条件2: 根据题目ID精确查询 -->
            <if test="param.teachingQuestion != null">
                AND sec.teaching_question = #{param.teachingQuestion}
            </if>
            <!-- 条件3: 根据答卷记录ID精确查询 -->
            <if test="param.recordId != null">
                AND sec.record_id = #{param.recordId}
            </if>
            <!-- 条件4: 根据题库ID精确查询 -->
            <if test="param.teachingQuestionBankId != null">
                AND sec.teaching_question_bank_id = #{param.teachingQuestionBankId}
            </if>
            <!-- 条件5: 根据作答内容模糊查询 -->
            <if test="param.content != null and param.content != ''">
                AND sec.content LIKE CONCAT('%', #{param.content}, '%')
            </if>
            <!-- 条件6: 根据作答结果模糊查询 -->
            <if test="param.result != null and param.result != ''">
                AND sec.result LIKE CONCAT('%', #{param.result}, '%')
            </if>
            <!-- 条件7: 根据得分精确查询 -->
            <if test="param.score != null">
                AND sec.score = #{param.score}
            </if>
        </where>
        ORDER BY sec.add_datetime
        <choose>
            <when test="param.isAsc == 1">ASC</when>
            <otherwise>DESC</otherwise>
        </choose>
    </select>
</mapper>
