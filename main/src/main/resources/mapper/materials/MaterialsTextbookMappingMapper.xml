<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.upc.modular.materials.mapper.MaterialsTextbookMappingMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.upc.modular.materials.entity.MaterialsTextbookMapping">
        <id column="id" property="id" />
        <result column="material_id" property="materialId" />
        <result column="textbook_id" property="textbookId" />
        <result column="view_count" property="viewCount" />
        <result column="download_count" property="downloadCount" />
    </resultMap>

    <select id="getPage" resultType="com.upc.modular.materials.controller.param.vo.MaterialsTextbookMappingReturnParam">
        SELECT
        m.id,
        m.material_id,
        m.textbook_id,
        t.name,
        t.type,
        m.chapter_name,
        te.name as uploader,
        m.add_datetime
        FROM
        materials_textbook_mapping m
        LEFT JOIN teaching_materials t ON m.material_id = t.id
        LEFT JOIN teacher te ON t.creator = te.id
        WHERE
        m.textbook_id = #{param.textbookId}
        <if test="param.materialName != null and param.materialName != ''">
            and t.name like concat('%',#{param.materialName},'%')
        </if>
        ORDER BY m.chapter_name ASC
    </select>
</mapper>
