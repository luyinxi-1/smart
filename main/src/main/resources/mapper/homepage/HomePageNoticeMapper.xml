<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.upc.modular.homepage.mapper.HomePageNoticeMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.upc.modular.homepage.entity.HomePageNotice">
        <id column="id" property="id" />
        <result column="title" property="title" />
        <result column="type" property="type" />
        <result column="content" property="content" />
        <result column="is_top" property="isTop" />
        <result column="creator" property="creator" />
        <result column="add_datetime" property="addDatetime" />
        <result column="operator" property="operator" />
        <result column="operation_datetime" property="operationDatetime" />
    </resultMap>
    <select id="getHomePageNoticeDetails" resultType="com.upc.modular.homepage.param.HomePageNoticeReturnParam"
            parameterType="java.lang.Long">
        SELECT
        hpn.*,
        COALESCE(t.name, s.name) AS authorName
        FROM
        home_page_notice hpn
        LEFT JOIN sys_tbuser u ON hpn.creator = u.id
        LEFT JOIN teacher t ON u.id = t.user_id AND u.user_type IN (0, 2)
        LEFT JOIN student s ON u.id = s.user_id AND u.user_type = 1

        <where>
            <if test="noticeId != null">
                AND hpn.id = #{noticeId}
            </if>
        </where>
    </select>

</mapper>
