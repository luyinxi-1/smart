<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.upc.modular.auth.mapper.RoleAuthorityListMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.upc.modular.auth.entity.RoleAuthorityList">
        <id column="id" property="id" />
        <result column="role_id" property="roleId" />
        <result column="authority_id" property="authorityId" />
        <result column="creator" property="creator" />
        <result column="add_datetime" property="addDatetime" />
        <result column="operator" property="operator" />
        <result column="operation_datetime" property="operationDatetime" />
    </resultMap>

    <delete id="myDeleteBatch">
        delete
        from role_authority_list
        where (role_id, authority_id) in
        <foreach collection="deleteList" open="(" separator="," close=")" item="item">
            (#{item.roleId},#{item.authorityId})
        </foreach>
    </delete>
</mapper>
