<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.upc.modular.auth.mapper.SysRoleMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.upc.modular.auth.entity.SysTbrole">
        <id column="id" property="id" />
        <result column="role_name" property="roleName" />
        <result column="status" property="status" />
        <result column="creator" property="creator" />
        <result column="add_datetime" property="addDatetime" />
        <result column="operator" property="operator" />
        <result column="operation_datetime" property="operationDatetime" />
    </resultMap>

    <!--获取所有根节点权限-->
    <select id="getAccessUrlsByRoleId" resultType="java.lang.String">
        SELECT a.access_url
        FROM sys_authority a
                 JOIN role_authority_list ra ON a.id = ra.authority_id
        WHERE ra.role_id = #{roleId}
          AND (a.id IS NULL OR a.id = 0) -- 获取根节点权限
    </select>

</mapper>
