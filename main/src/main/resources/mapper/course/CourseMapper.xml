<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.upc.modular.course.mapper.CourseMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.upc.modular.course.entity.Course">
        <id column="id" property="id" />
        <result column="textbook_id" property="textbookId" />
        <result column="course_name" property="courseName" />
        <result column="credit" property="credit" />
        <result column="description" property="description" />
        <result column="status" property="status" />
        <result column="teacher_id" property="teacherId" />
        <result column="creator" property="creator" />
        <result column="add_datetime" property="addDatetime" />
        <result column="operator" property="operator" />
        <result column="operation_datetime" property="operationDatetime" />
    </resultMap>

    <select id="selectCourse"
            resultType="com.upc.modular.course.controller.param.CoursePageReturnParam">
        SELECT
        c.id,
        c.textbook_id AS textbookId,
        c.course_name AS courseName,
        c.credit,
        c.description,
        c.status,
        t.id AS teacherId,
        t.name AS teacherName,
        u.username AS creatorName,
        c.add_datetime AS addDatetime,
        c.course_picture AS coursePicture
        FROM course c
        LEFT JOIN teacher t
        ON c.teacher_id = t.id
        LEFT JOIN sys_tbuser u
        ON c.creator = u.id
        <where>
            <!-- 条件1: 课程名称模糊 -->
            <if test="param.courseName != null and param.courseName != ''">
                AND c.course_name LIKE CONCAT('%', #{param.courseName}, '%')
            </if>
            <!-- 条件2: 教师姓名模糊（用 t.name 过滤） -->
            <if test="param.teacherName != null and param.teacherName != ''">
                AND t.name LIKE CONCAT('%', #{param.teacherName}, '%')
            </if>
        </where>
        ORDER BY c.add_datetime
        <choose>
            <when test="param.isAsc == 1">ASC</when>
            <otherwise>DESC</otherwise>
        </choose>
    </select>

</mapper>
